rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function playerIds(data) {
      return data.get('playerIds', []);
    }

    function isMember(data) {
      return isSignedIn() && request.auth.uid in playerIds(data);
    }

    function isWaiting(data) {
      return data.get('status', '') == 'waiting';
    }

    function isValidJoin() {
      return isSignedIn()
        && isWaiting(resource.data)
        && isWaiting(request.resource.data)
        && !(request.auth.uid in playerIds(resource.data))
        && request.auth.uid in playerIds(request.resource.data)
        && playerIds(request.resource.data).size()
            == playerIds(resource.data).size() + 1
        && request.resource.data.players.size()
            == resource.data.players.size() + 1;
    }

    function profileFields() {
      return [
        'displayName', 'photoUrl', 'lastActiveAt', 'isOnline', 'activeRoomCode',
        'updatedAt', 'friendCode', 'equippedTitle'
      ];
    }

    function progressFields() {
      return [
        'coins', 'gamesPlayed', 'offlineWins', 'onlineJoins', 'onlineWins',
        'unlockedTitles', 'seenUnlocks'
      ];
    }

    function validUserCreate() {
      return request.resource.data.get('coins', 0) >= 0
        && request.resource.data.get('coins', 0) <= 500
        && request.resource.data.get('gamesPlayed', 0) >= 0
        && request.resource.data.get('gamesPlayed', 0) <= 50
        && request.resource.data.get('offlineWins', 0) >= 0
        && request.resource.data.get('offlineWins', 0) <= 50
        && request.resource.data.get('onlineJoins', 0) >= 0
        && request.resource.data.get('onlineJoins', 0) <= 50
        && request.resource.data.get('onlineWins', 0) >= 0
        && request.resource.data.get('onlineWins', 0) <= 50;
    }

    function validProgressDelta() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      let hasProgress = affected.hasAny(progressFields());
      let old = resource.data;
      let neu = request.resource.data;
      let coinsDelta = neu.get('coins', 0) - old.get('coins', 0);
      let coinsOk = !affected.hasAny(['coins'])
        || (
          neu.get('coins', 0) >= 0
          && neu.get('coins', 0) <= 200000
          && coinsDelta <= 500
          && coinsDelta >= -50000
        );
      let gpOk = !affected.hasAny(['gamesPlayed'])
        || (
          neu.get('gamesPlayed', 0) >= old.get('gamesPlayed', 0)
          && neu.get('gamesPlayed', 0) <= 100000
          && neu.get('gamesPlayed', 0) - old.get('gamesPlayed', 0) <= 15
        );
      let owOk = !affected.hasAny(['offlineWins'])
        || (
          neu.get('offlineWins', 0) >= old.get('offlineWins', 0)
          && neu.get('offlineWins', 0) <= 100000
          && neu.get('offlineWins', 0) - old.get('offlineWins', 0) <= 5
        );
      let ojOk = !affected.hasAny(['onlineJoins'])
        || (
          neu.get('onlineJoins', 0) >= old.get('onlineJoins', 0)
          && neu.get('onlineJoins', 0) <= 100000
          && neu.get('onlineJoins', 0) - old.get('onlineJoins', 0) <= 10
        );
      let ow2Ok = !affected.hasAny(['onlineWins'])
        || (
          neu.get('onlineWins', 0) >= old.get('onlineWins', 0)
          && neu.get('onlineWins', 0) <= 100000
          && neu.get('onlineWins', 0) - old.get('onlineWins', 0) <= 5
        );
      let titlesOk = !affected.hasAny(['unlockedTitles', 'seenUnlocks'])
        || (
          neu.get('unlockedTitles', []).size() <= 64
          && neu.get('seenUnlocks', []).size() <= 64
        );
      return !hasProgress || (coinsOk && gpOk && owOk && ojOk && ow2Ok && titlesOk);
    }

    function validFriendRequestUpdate() {
      return resource.data.status == 'pending'
        && request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toUid == resource.data.toUid
        && (
          (
            resource.data.toUid == request.auth.uid
            && request.resource.data.status in ['accepted', 'declined']
          )
          || (
            resource.data.fromUid == request.auth.uid
            && request.resource.data.status == 'cancelled'
          )
        );
    }

    function validFriendshipCreate() {
      let reqId = request.resource.data.get('sourceRequestId', '');
      let reqPath = /databases/$(database)/documents/friend_requests/$(reqId);
      let req = get(reqPath).data;
      return isSignedIn()
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members.size() == 2
        && reqId != ''
        && exists(reqPath)
        // get() trong transaction không thấy update cùng batch → chấp nhận pending hoặc accepted.
        && req.toUid == request.auth.uid
        && req.status in ['pending', 'accepted']
        && request.resource.data.members.hasAll([req.fromUid, req.toUid]);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && validUserCreate();
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && validProgressDelta();

      match /room_invites/{inviteId} {
        allow read, delete: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn()
          && request.resource.data.fromUid == request.auth.uid
          && request.auth.uid != userId
          && request.resource.data.roomCode is string
          && request.resource.data.roomCode.size() == 6;
      }
    }

    match /friend_codes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/friend_codes/$(code));
      allow update: if false;
    }

    match /friend_requests/{requestId} {
      allow get: if isSignedIn()
        && (
          resource == null
          || resource.data.fromUid == request.auth.uid
          || resource.data.toUid == request.auth.uid
        );
      allow list: if isSignedIn()
        && (
          resource.data.fromUid == request.auth.uid
          || resource.data.toUid == request.auth.uid
        );
      allow create: if isSignedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid != request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isSignedIn() && validFriendRequestUpdate();
      allow delete: if false;
    }

    match /friendships/{friendshipId} {
      allow get: if isSignedIn()
        && (
          resource == null
          || request.auth.uid in resource.data.get('members', [])
        );
      allow list: if isSignedIn()
        && request.auth.uid in resource.data.get('members', []);
      allow create: if validFriendshipCreate();
      allow update, delete: if false;
    }

    match /rooms/{roomId} {
      allow read: if isSignedIn()
        && (
          !exists(/databases/$(database)/documents/rooms/$(roomId))
          || isMember(resource.data)
          || isWaiting(resource.data)
        );

      allow create: if isSignedIn()
        && request.resource.data.hostId == request.auth.uid
        && request.auth.uid in playerIds(request.resource.data)
        && playerIds(request.resource.data).size() == 1
        && request.resource.data.players.size() == 1
        && isWaiting(request.resource.data);

      allow update: if isSignedIn()
        && (isMember(resource.data) || isValidJoin());

      allow delete: if isMember(resource.data);
    }
  }
}
